<ArcGIS defaultAssembly="APBridgeAddIn.dll" defaultNamespace="APBridgeAddIn" xmlns="http://schemas.esri.com/DADF/Registry" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://schemas.esri.com/DADF/Registry file:///C:/Program%20Files/ArcGIS/Pro/bin/ArcGIS.Desktop.Framework.xsd">
  <AddInInfo id="{c56ccfd4-f12a-4916-84c2-64248b3d746c}" version="1.0" desktopVersion="3.6.59527" product="ArcGISPro">
    <Name>APBridgeAddIn</Name>
    <Description>MCP Server bridge for ArcGIS Pro - enables Claude to interact with Pro via ModelContext Protocol</Description>
